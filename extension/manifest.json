{
  "manifest_version": 3,
  "name": "ToneGuard",
  "version": "1.0",
  "description": "Real-time tone detection for your messages",

  "permissions": [
    "activeTab",
    "storage"
  ],

  "host_permissions": [
    "https://toneguard-api.onrender.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
  {
    "matches": ["<all_urls>"],
    "exclude_matches": [
      "*://www.google.com/*",
      "*://google.com/*"
    ],
    "js": [
      "tfjs/tf.min.js",
      "classifier.js",
      "content.js"
    ],
    "css": ["content.css"]
  }
],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon48.png"
    }
  },

  "icons": {
    "48": "icons/icon48.png"
  },

  "web_accessible_resources": [
    {
      "resources": ["tfjs_model/*"],
      "matches": ["<all_urls>"]
    }
  ]
}